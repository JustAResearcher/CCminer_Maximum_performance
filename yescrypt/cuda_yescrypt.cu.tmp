/* Extracted Salsa20 core — __noinline__ for separate register scope on SM 89 */
__device__ __noinline__ uint32_t salsa_core_noinline(uint32_t x0_in, uint32_t x1_in, uint32_t x2_in, uint32_t x3_in, int threadIdx_x)
{
    uint32_t x0 = x0_in, x1 = x1_in, x2 = x2_in, x3 = x3_in;
    uint32_t t0 = x0, t1 = x1, t2 = x2, t3 = x3;
    for (int idx = 0; idx < 4; ++idx) {
        SALSA(x0, x1, x2, x3);
        WarpShuffle3(x1,x2,x3,x1,x2,x3,threadIdx_x + 3,threadIdx_x + 2,threadIdx_x + 1,4);
        SALSA(x0, x3, x2, x1);
        WarpShuffle3(x1,x2,x3,x1,x2,x3,threadIdx_x + 1,threadIdx_x + 2,threadIdx_x + 3,4);
    }
    x0 += t0; x1 += t1; x2 += t2; x3 += t3;
    if (threadIdx_x < 4) return x0;
    else if (threadIdx_x < 8) return x1;
    else if (threadIdx_x < 12) return x2;
    else return x3;
}
